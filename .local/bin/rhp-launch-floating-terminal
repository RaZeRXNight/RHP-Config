#!/bin/bash

# rhp:summary=Launch a floating terminal with the RHP presentation wrapper
# rhp:args=<command>

cmd="$*"
terminal=alacritty
shell=bash

setsid uwsm-app -- $terminal --title floating -e $shell -c "$cmd" &
PID=$!

for i in $(seq 1 100); do
  if hyprctl clients -j | jq -e ".[] | select(.pid == $PID) | .address" >/dev/null 2>&1; then
    hyprctl dispatch "hl.dsp.window.float({ action = \"toggle\", window = \"pid:$PID\" })" 2>/dev/null
    hyprctl dispatch "hl.dsp.window.center({ window = \"pid:$PID\" })" 2>/dev/null
    break
  fi
  sleep 0.05
done

wait $PID
