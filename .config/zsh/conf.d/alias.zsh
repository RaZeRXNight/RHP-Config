# Aliases
alias c='opencode'                                                        # clear terminal
alias l='lsd -lh '                                         # long list
alias ls='lsd'                                             # short list
alias lsa='lsd -a'                                             # short list
alias ll='lsd -lha  --sort=size --group-directories-first' # long list all
alias ld='lsd -lhD '                                       # long list dirs
alias lt='lsd  --tree'                                     # list folder as tree
alias un='$aurhelper -Rns'
alias up='$aurhelper -Syu'
alias pl='$aurhelper -Qs'
alias pa='$aurhelper -Ss'
alias pc='$aurhelper -Sc'
alias po='$aurhelper -Qtdq | $aurhelper -Rns -'
alias vc='code'                                                        # gui code editor
alias fastfetch='fastfetch '

